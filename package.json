{
  "name": "magic-protege",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prettier": "prettier --write .",
    "dev": "next dev --webpack",
    "build": "NODE_ENV=production next build --webpack",
    "start": "next start",
    "lint": "npm run lint:js && npm run lint:styles",
    "lint:js": "eslint --max-warnings=0",
    "lint:styles": "stylelint \"**/*.css\"",
    "test:integration": "vitest run --config=vitest.config.ts",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx ./scripts/db-migrate.ts",
    "db:migrate:test": "ENV_FILE=.env.test tsx ./scripts/db-migrate.ts",
    "db:baseline:reset": "tsx ./scripts/reset-drizzle-baseline.ts",
    "db:baseline:rebuild": "npm run db:baseline:reset && npm run db:generate",
    "db:seed": "tsx --env-file=.env ./src/db/seed.ts --reset",
    "db:seed:append": "tsx --env-file=.env ./src/db/seed.ts",
    "db:seed:reset": "tsx --env-file=.env ./src/db/seed.ts --reset",
    "db:setup": "npm run db:migrate && tsx --env-file=.env ./src/db/seed.ts --if-empty",
    "infra:test:up": "docker compose --env-file .env.test -f compose.yml -f compose.test.yml up -d --wait db session",
    "infra:test:down": "docker compose --env-file .env.test -f compose.yml -f compose.test.yml down -v",
    "auth:check-cookie": "tsx ./scripts/utils/check-cookie.ts",
    "auth:check-password": "tsx ./scripts/utils/check-password.ts",
    "auth:check-session": "tsx ./scripts/utils/check-session.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/react": "^3.0.182",
    "ai": "^6.0.180",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.45.2",
    "magic-crayon": "^1.0.0-rc.3",
    "next": "^16.2.6",
    "next-intl": "^4.12.0",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "redis": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/eslint-plugin": "^1.6.18",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "eslint": "9.39.3",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "3.8.1",
    "stylelint": "^17.11.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.22.3",
    "typescript": "5.9.3",
    "vitest": "^4.1.7"
  },
  "prettier": {
    "arrowParens": "avoid",
    "printWidth": 90,
    "semi": false,
    "singleQuote": true
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md,html,yml}": "prettier --write",
    "*.{js,ts,tsx}": "eslint --fix"
  },
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Firefox versions",
      "last 2 Safari versions",
      "last 2 Edge versions"
    ],
    "development": [
      "last 1 Chrome version",
      "last 1 Firefox version",
      "last 1 Safari version"
    ]
  }
}
